---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderAstro from '../components/HeaderAstro.astro';
import Hero from '../components/Hero';
import TrustBar from '../components/TrustBar';
import ProblemAwareness from '../components/ProblemAwareness';
import Solution from '../components/Solution';
import Pricing from '../components/Pricing';
import SimpleCaseStudy from '../components/SimpleCaseStudy';
import FAQ from '../components/FAQ';
import Contact from '../components/Contact';
import Footer from '../components/Footer';
import CookieBanner from '../components/CookieBanner';
import MobileStickyBar from '../components/MobileStickyBar';
import StickyDesktopCTA from '../components/StickyDesktopCTA';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  'name': 'LeventeStudio - Weboldal Készítés Kisvállalkozásoknak',
  'description': 'Ügyfélszerző weboldalak kisvállalkozásoknak. SEO optimalizált, gyors, mobilbarát weboldalak 5-7 nap alatt.',
  'image': 'https://leventestudio.app/logo.png',
  'logo': {
    '@type': 'ImageObject',
    'url': 'https://leventestudio.app/logo.png',
    'width': 512,
    'height': 512
  },
  'provider': {
    '@type': 'Person',
    'name': 'Levente Csurka',
    'jobTitle': 'Webfejlesztő',
    'telephone': '+36202826843',
    'email': 'hello@leventestudio.app',
    'url': 'https://leventestudio.app',
    'image': 'https://leventestudio.app/levente_studio_portrait_final.webp',
    'logo': {
      '@type': 'ImageObject',
      'url': 'https://leventestudio.app/logo.png',
      'width': 512,
      'height': 512
    }
  },
  'areaServed': 'HU',
  'serviceType': ['Weboldal Készítés', 'SEO Optimalizálás', 'Landing Page Készítés'],
  'address': {
    '@type': 'PostalAddress',
    'addressCountry': 'HU'
  },
  'priceRange': '250000-750000 HUF'
};
---

<BaseLayout
  title="Weboldal Készítés Kisvállalkozásoknak | Ügyfélszerző Honlap 5-7 Nap Alatt | LeventeStudio"
  description="Ügyfélszerző weboldal kisvállalkozásoknak 5-7 nap alatt. Megépítjük, beindítjuk, megtanítjuk használni. SEO optimalizált, gyors, professzionális. Átlátható árak 250.000 Ft-tól."
  canonical="/"
  structuredData={structuredData}
>
  <CookieBanner client:load />
  <MobileStickyBar client:load />
  <StickyDesktopCTA client:load />

  <div class="min-h-screen bg-white">
    <HeaderAstro />
    <Hero client:load />
    <TrustBar client:load />
    <ProblemAwareness client:load />
    <Solution client:load />
    <Pricing client:load />
    <SimpleCaseStudy client:load />
    <FAQ client:load />
    <Contact client:load />
    <Footer client:load />
  </div>
</BaseLayout>
